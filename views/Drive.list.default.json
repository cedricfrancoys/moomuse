{
    "name": "Drives",
    "description": "Default list view for drives.",
    "actions": [
        {
            "id": "action.scan",
            "inline": true,
            "label": "Scan",
            "icon": "sync",
            "description": "Scan this drive and create missing directories and tracks.",
            "controller": "moomuse_Drive_scan",
            "params": {
                "id": "object.id"
            }
        }
    ],
    "layout": {
        "items": [
            {
                "type": "field",
                "value": "name",
                "width": "15%"
            },
            {
                "type": "field",
                "value": "mount_point",
                "width": "35%"
            },
            {
                "type": "field",
                "value": "volume_serial",
                "width": "25%"
            },
            {
                "type": "field",
                "value": "device_id",
                "width": "20%"
            },
            {
                "type": "field",
                "value": "status",
                "width": "15%",
                "sortable": true
            },
            {
                "type": "field",
                "value": "last_scanned_at",
                "width": "15%",
                "sortable": true
            }
        ]
    }
}
